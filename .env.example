# PORT (local only — Vercel assigns its own port)
PORT=5500

# NODE_ENV: "development" en local, "production" sur Vercel
NODE_ENV=development

# URL du frontend autorisée par CORS
# Local : http://localhost:5173
# Prod  : https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# URL de base de l'API (utilisée pour construire les URLs d'upload)
# Local : http://localhost:5500
# Prod  : https://your-api.vercel.app
BASE_URL=http://localhost:5500

# MongoDB Atlas connection string
MONGO_URI=

# JWT
JWT_SECRET=changeme
JWT_EXPIRES_IN=7d
JWT_LIMITED_EXPIRES_IN=7d
INVITE_EXPIRE_DAYS=7

# RESEND MAILER
RESEND_API_KEY=
